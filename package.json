{
  "name": "malachia",
  "version": "1.0.0",
  "description": "Malachia — bibliotheca privata personale",
  "scripts": {
    "start": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"yellow,cyan\" \"npm run backend\" \"npm run frontend\"",
    "backend": "npm --prefix backend start",
    "frontend": "npm --prefix frontend run dev",
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install",
    "seed:tolkien": "node backend/src/seed/tolkien-seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
