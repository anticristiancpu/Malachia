# ========================================
# Malachia — Configurazione (.env.example)
# Copia questo file in .env e modifica i valori
# ========================================

# Porta backend (default: 3001)
BACKEND_PORT=3001

# URL frontend per CORS (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Percorso database SQLite (default: ./data/malachia.db)
# DB_PATH=./data/malachia.db

# ========================================
# API ESTERNE (tutte opzionali)
# ========================================

# Google Books API Key
# Senza chiave funziona con rate limit più severo.
# Ottieni da: https://console.cloud.google.com/apis/library/books.googleapis.com
# GOOGLE_BOOKS_API_KEY=AIzaSy...

# Hardcover API Token
# Ottieni da: https://hardcover.app/account/developer
# HARDCOVER_TOKEN=...

# Amazon Product Advertising API (opzionale)
# AMAZON_ACCESS_KEY=...
# AMAZON_SECRET_KEY=...
# AMAZON_PARTNER_TAG=...

# ========================================
# INTEGRAZIONE GRIMMORY (opzionale)
# ========================================
# Grimmory è un gestore ebook self-hosted (porta 6060 di default).
# Assicurarsi che nel .env di Grimmory sia impostato: API_DOCS_ENABLED=true
#
# GRIMMORY_URL=http://localhost:6060
# GRIMMORY_USER=admin
# GRIMMORY_PASSWORD=password
# GRIMMORY_SYNC_INTERVAL=3600   # secondi tra sync automatiche (default: disabilitato)
